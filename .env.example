# Backend Environment Variables (set these in Railway)

# Required in production
JWT_SECRET=your-super-secret-key-here

# Optional (defaults shown)
PORT=3000
NODE_ENV=production
JWT_EXPIRES_IN=8h
DATABASE_PATH=/tmp/data/heart_erp.db
FRONTEND_URL=https://your-app.vercel.app
ADMIN_EMAIL=admin@heartfoundation.org

# Frontend Environment Variables (set these in Vercel)

# Required - your Railway backend URL
VITE_API_URL=https://your-app.up.railway.app

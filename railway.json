{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install && npm rebuild better-sqlite3 && npm run build",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "mkdir -p /tmp/data && cd backend && node dist/server.mjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
